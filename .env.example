# Copy to .env and adjust. Values are read by scripts/daily_job.py and kalimati.dashboard.

# SQLite path (default: ./data/prices.db)
KALIMATI_DB_PATH=data/prices.db

# PNG root folder; each run writes under ./output/YYYY-MM-DD/page-NN.png
KALIMATI_OUTPUT_DIR=output

# Optional: ntfy.sh topic (public). Example: mytopic123
# If set, daily job POSTs when any item is cheaper than the last recorded day.
KALIMATI_NTFY_TOPIC=

# Optional: generic webhook URL (POST JSON body). Used if NTFY not set.
KALIMATI_WEBHOOK_URL=

# Optional: Facebook Page photo upload (requires app with pages_manage_posts)
# KALIMATI_FACEBOOK_PAGE_ID=
# KALIMATI_FACEBOOK_ACCESS_TOKEN=

# Dashboard bind (default 127.0.0.1:8765)
KALIMATI_DASHBOARD_HOST=127.0.0.1
KALIMATI_DASHBOARD_PORT=8765
